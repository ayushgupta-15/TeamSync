{
  "name": "teamsync",
  "version": "1.0.0",
  "description": "TeamSync – B2B Project Management Platform (Monorepo)",
  "private": true,
  "workspaces": [
    "apps/client",
    "apps/server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run dev --workspace=apps/server\" \"npm run dev --workspace=apps/client\"",
    "dev:server": "npm run dev --workspace=apps/server",
    "dev:client": "npm run dev --workspace=apps/client",
    "build": "npm run build --workspace=apps/server && npm run build --workspace=apps/client",
    "build:server": "npm run build --workspace=apps/server",
    "build:client": "npm run build --workspace=apps/client",
    "start": "npm run start --workspace=apps/server",
    "lint": "npm run lint --workspace=apps/client",
    "test": "npm run test --workspace=apps/server",
    "test:server": "npm run test --workspace=apps/server",
    "seed": "npm run seed --workspace=apps/server",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "teamsync",
    "project-management",
    "monorepo",
    "fullstack",
    "typescript"
  ],
  "author": "ayushgupta-15",
  "license": "MIT"
}
