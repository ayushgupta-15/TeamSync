# ──────────────────────────────────────────────────────────────────────────────
# TeamSync Monorepo — Environment Variables Template
# Copy this file to .env in the respective package folder:
#   apps/server/.env   (required)
#   apps/client/.env   (optional, Vite uses defaults)
# ──────────────────────────────────────────────────────────────────────────────

# ── SERVER (apps/server/.env) ──────────────────────────────────────────────────

NODE_ENV=development
PORT=8000
BASE_PATH=/api

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/teamsync

# Session
SESSION_SECRET=your_session_secret_here
SESSION_EXPIRES_IN=7d

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/google/callback

# CORS — URL of the frontend
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_GOOGLE_CALLBACK_URL=http://localhost:5173/google/oauth/callback

# ── CLIENT (apps/client/.env) ──────────────────────────────────────────────────

VITE_API_BASE_URL=http://localhost:8000/api/v1
